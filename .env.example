# Required for Telegram notifications
TELEGRAM_BOT_TOKEN=1234567890:replace_me
TELEGRAM_CHAT_ID=123456789

# Optional: exact commute scoring. Without this, the bot uses the SF/East Bay
# neighborhood whitelist in src/filters.py.
GOOGLE_MAPS_API_KEY=

# Optional: personalized opener. Without this, config.yaml reply.fallback_hook is used.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional: Twilio SMS. Only needed if config.yaml notification.channel = twilio.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional: Facebook Marketplace experimental source.
# This should be a JSON array of cookies exported from a throwaway FB account.
FB_COOKIES_JSON=
